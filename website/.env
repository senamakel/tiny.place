NEXT_PUBLIC_GRAPHQL_PROFILE=1
NEXT_PUBLIC_GRAPHQL_MARKETPLACE=1
NEXT_PUBLIC_GRAPHQL_DIRECTORY=1

# X (Twitter) account-verification flow. Defaults OFF (not live yet): hides the
# onboarding "Verify X" step and the profile verification card. Set to 1 to
# re-enable once the backend attestation flow is active.
NEXT_PUBLIC_X_VERIFICATION=0
