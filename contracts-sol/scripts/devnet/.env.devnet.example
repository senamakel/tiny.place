# Devnet deploy + test configuration.
#
# Copy to `.env.devnet` (gitignored) and fill in. NEVER commit this file or paste
# its contents into chat.
#
# Each signing role accepts EITHER a raw private key (simplest) OR a keypair file:
#   <ROLE>_PRIVATE_KEY  — base58 secret (Phantom export) or JSON byte array
#   <ROLE>_KEYPAIR      — path to a solana CLI keypair .json file
# If you give a PRIVATE_KEY, the scripts write a temp keypair file just for the
# command and delete it on exit (the solana CLI itself requires a file).

# RPC endpoint for devnet (your custom RPC, or https://api.devnet.solana.com).
DEVNET_RPC_URL=https://api.devnet.solana.com

# Deployer/payer: funded with devnet SOL. Pays deploy rent (~7 SOL for all 4
# programs) and becomes each program's upgrade authority. Also the USDC source
# for tests.
DEPLOYER_PRIVATE_KEY=
# DEPLOYER_KEYPAIR=scripts/devnet/keys/deployer.json   # alternative to the above

# Relay / server authority: used in tests as the job controller, poker settler,
# and lottery drawer (the trusted off-chain decision-maker).
RELAY_PRIVATE_KEY=
# RELAY_KEYPAIR=scripts/devnet/keys/relay.json

# OPTIONAL: your own tester wallet. If you provide its PRIVATE KEY, the e2e makes
# it a visible participant (job provider + the poker/lottery winner). A pubkey
# alone can't be used — settlement participants must sign.
TESTER_PRIVATE_KEY=
# TESTER_KEYPAIR=scripts/devnet/keys/tester.json
TESTER_PUBKEY=

# The SPL mint of your devnet test USDC. The contracts are mint-agnostic, so any
# SPL mint works. Circle's devnet USDC is 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT=

# Per-flow amount in token BASE UNITS (USDC has 6 decimals -> 10000 = 0.01 USDC).
# Kept small so a full e2e run costs almost nothing.
AMOUNT_BASE=10000
